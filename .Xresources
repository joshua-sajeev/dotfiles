XTerm.termName: xterm0256color

XTerm*VT100.geometry:130x50

XTerm*faceSize: 14
XTerm*faceName: SauceCodePro

XTerm*faceSize1: 8
XTerm*faceSize2: 10
XTerm*faceSize3: 12
XTerm*faceSize4: 16
XTerm*faceSize5: 22
XTerm*faceSize6: 24

XTerm*vt100.scrollBar: false

! Do not scroll when there is new input
XTerm*scrollTtyOutput: false

! Scrolling by using Shift-PageUp / Shift-PageDown or mousewheel by default ##
! Lines of output you can scroll back over
XTerm*saveLines: 15000

! Enable copy/paste hotkeyes (mouse highlight = copy ,  shift+Insert = paste)
XTerm*selectToClipboard: true

! ## Select text ##
XTerm*highlightSelection: true
! Remove trailing spaces
XTerm*trimSelection: true

! ## Keybindings ##
XTerm*vt100.translations: #override \n\
  Ctrl <Key>-: smaller-vt-font() \n\
  Ctrl <Key>+: larger-vt-font() \n\
  Ctrl <Key>0: set-vt-font(d) \n\
  Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
  Ctrl Shift <Key>V: insert-selection(CLIPBOARD)

! ~~~~~~~~~~~~~~~~~~
! ## Color Themes ## 
! ~~~~~~~~~~~~~~~~~~
!
! based on snazzy color theme
! https://github.com/olstenlarck/urxvt-xterm-snazzy/blob/7c34009a19ade65271e26ef065c678b0fa2abd0d/.Xdefaults
!
XTerm*title: XTerminal
XTerm*background: #0d0f18
XTerm*foreground: #fffaf3

! original #86a2b0
XTerm*colorUL: #eff0eb
XTerm*underlineColor: #eff0eb

XTerm*color0  : #222222
XTerm*color8  : #444444
XTerm*color1  : #ff000f
XTerm*color9  : #ff273f
XTerm*color2  : #17c419
XTerm*color10 : #9bec13
XTerm*color3  : #ffb900
XTerm*color11 : #ffd141
XTerm*color4  : #008df8
XTerm*color12 : #0092ff
XTerm*color5  : #6c43a5
XTerm*color13 : #9a5feb
XTerm*color6  : #00d7eb
XTerm*color14 : #67ffef
XTerm*color7  : #ffffff
XTerm*color15 : #ffffff

